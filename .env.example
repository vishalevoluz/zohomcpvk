# Zoho MCP URL (can also be entered in the UI)
NEXT_PUBLIC_ZOHO_MCP_URL=https://your-zoho-mcp-url.com/mcp

# Optional auth (can also be entered in the UI)
NEXT_PUBLIC_ZOHO_TOKEN=your-bearer-token
NEXT_PUBLIC_ZOHO_API_KEY=your-api-key

# Used only by the Zia Recommendations card's "Get remediation steps" action
ANTHROPIC_API_KEY=your-anthropic-api-key
